# Copy to ~/servers/secrets.env and fill in real values — never commit that
# file. chmod 600 it. One shared env file for both romm containers (each
# ignores the other's variables). No inline comments: values run to EOL.
#
# romm application
DB_USER=TBD
DB_PASSWD=TBD
ROMM_AUTH_SECRET_KEY=TBD
# romm-db (MariaDB) — MARIADB_USER/PASSWORD must match DB_USER/DB_PASSWD
MARIADB_ROOT_PASSWORD=TBD
MARIADB_USER=TBD
MARIADB_PASSWORD=TBD
